### Grants UI Config API - HTTP Client

### Health Check
# @name HealthCheck
GET {{baseUrl}}/health
x-api-key: {{x-api-key}}

###

### List Live Slugs
# @name ListLiveSlugs
GET {{baseUrl}}/forms/slugs
x-api-key: {{x-api-key}}

###

### List Forms
# @name ListForms
GET {{baseUrl}}/forms
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### List Forms with Query Parameters
# @name ListFormsWithQuery
GET {{baseUrl}}/forms?organisations=Defra
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Create Form (requires auth)
# @name CreateForm
POST {{baseUrl}}/forms
Content-Type: application/json
Authorization: Bearer {{authToken}}
x-api-key: {{x-api-key}}

{
  "title": "Sample Form",
  "organisation": "Defra",
  "teamName": "Test Team",
  "teamEmail": "test.team.email@defra.gov.uk",
  "slug": "sample"
}

> {%
  client.global.set("formId", response.body.id);
  client.global.set("slug", "sample");
%}

###

### Default versionNumber (editor workflow)
@versionNumber=1

### Default semver (config broker workflow)
@semver=1.0.0

### Default slug (config broker workflow)
@slug=example-grant-with-auth

###

### Get Form by ID
# @name GetFormById
GET {{baseUrl}}/forms/{{formId}}
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Get Form by Slug
# @name GetFormBySlug
GET {{baseUrl}}/forms/slug/{{slug}}
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Get Latest Active Form Definition by Slug (config broker forms)
# @name GetLatestActiveDefinitionBySlug
GET {{baseUrl}}/forms/slug/{{slug}}/definition
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Get Specific Semver Form Definition by Slug
# @name GetDefinitionBySlugAndVersion
GET {{baseUrl}}/forms/slug/{{slug}}/definition?version={{semver}}
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Get Form Metadata by Slug with Semver (optional)
# @name GetFormBySlugWithVersion
GET {{baseUrl}}/forms/slug/{{slug}}?version={{semver}}
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Update Form Metadata (requires auth)
# @name UpdateFormMetadata
PATCH {{baseUrl}}/forms/{{formId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}
x-api-key: {{x-api-key}}

{
  "title": "Updated Form Title"
}

###

### Delete Form (requires auth)
# @name DeleteForm
DELETE {{baseUrl}}/forms/{{formId}}
Authorization: Bearer {{authToken}}
x-api-key: {{x-api-key}}

###

### Get Draft Form Definition
# @name GetDraftDefinition
GET {{baseUrl}}/forms/{{formId}}/definition/draft
x-api-key: {{x-api-key}}
Accept-Encoding: identity

###

### Update Draft Form Definition (requires auth)
# @name UpdateDraftDefinition
POST {{baseUrl}}/forms/{{formId}}/definition/draft
Content-Type: application/json
Authorization: Bearer {{authToken}}
x-api-key: {{x-api-key}}

{
  "engine": "V2",
  "schema": 2,
  "metadata": {
    "id": "9f9c5ec4-e237-4e6e-b67c-f232a6377d76",
    "enabledInProd": false,
    "referenceNumberPrefix": "EGWA",
    "cookieConsent": {
      "enabled": true,
      "serviceName": "Farm and land service",
      "cookiePolicyUrl": "/cookies",
      "expiryDays": 365
    },
    "submission": {
      "grantCode": "example-grant-with-auth-v3",
      "submissionSchemaPath": "./schemas/example-grant-with-auth-submission.schema.json"
    },
    "grantRedirectRules": null,
    "confirmationContent": {
      "panelTitle": "Details submitted",
      "panelText": "Your reference number",
      "html": "<h2 class=\"govuk-heading-m\">What happens next</h2>\n<p class=\"govuk-body\">Defra will email you when your funding offer is available to review. This will be within 5 working days.</p>\n<p class=\"govuk-body\">You will need to sign in to the service to accept your funding offer.</p>\n<p class=\"govuk-body\">You should not start work on the actions you have applied for until:</p>\n<ul class=\"govuk-list govuk-list--bullet govuk-!-margin-bottom-6\">\n  <li>you have accepted your offer</li>\n  <li>the Rural Payments Agency confirms your start date</li>\n</ul>\n\n<details class=\"govuk-details\" data-module=\"govuk-details\">\n  <summary class=\"govuk-details__summary\">\n    <span class=\"govuk-details__summary-text\">\n      If you have a question\n    </span>\n  </summary>\n  <div class=\"govuk-details__text\">\n    <p class=\"govuk-body\">Contact the Rural Payments Agency if you have a query.</p>\n    <p class=\"govuk-body\">\n      Telephone: 03000 200 301<br>\n      Monday to Friday, 8:30am to 5pm (except bank holidays)</p>\n    <p class=\"govuk-body\"><a class=\"govuk-link\" href=\"https://www.gov.uk/call-charges\" target=\"_blank\">Find out about call charges (opens in new tab)</a></p>\n    <p class=\"govuk-body\">Email: <a class=\"govuk-link\" href=\"mailto:ruralpayments@defra.gov.uk\">ruralpayments@defra.gov.uk</a></p>\n  </div>\n</details>"
    },
    "tasklist": {
      "completeInOrder": true,
      "returnAfterSection": true,
      "showCompletionStatus": true,
      "statuses": {
        "cannotStart": {
          "text": "Cannot start yet",
          "classes": "govuk-tag--grey"
        },
        "notStarted": {
          "text": "Not started",
          "classes": "govuk-tag--blue"
        },
        "completed": {
          "text": "Completed",
          "classes": "govuk-tag--green"
        }
      }
    }
  },
  "pages": [],
  "lists": [],
  "sections": [],
  "conditions": []
}

