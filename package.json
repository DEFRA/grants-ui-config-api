{
  "name": "@defra/grants-ui-config-api",
  "version": "0.0.0",
  "private": true,
  "description": "Defra grants UI config API",
  "license": "OGL-UK-3.0",
  "author": "Defra DDTS",
  "type": "module",
  "main": ".server/index.js",
  "scripts": {
    "build": "npm run build:server",
    "build:server": "babel --delete-dir-on-start --ignore \"**/*.test.js\" --ignore \"src/__fixtures__\" --copy-files --no-copy-ignored --keep-file-extension --source-maps --out-dir ./.server ./src",
    "dev": "npm run server:watch:dev",
    "dev:debug": "npm run server:watch:debug",
    "docker:build": "docker build -t grants-ui-config-api:local .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:debug": "docker compose run --service-ports --rm grants-ui-config-api npm run dev:debug",
    "docker:reset": "docker compose down --volumes --remove-orphans --rmi local",
    "format": "prettier --write \"**/*.{cjs,js,json,md,mjs}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md,mjs}\"",
    "postinstall": "npm run setup:husky",
    "lint": "npm run lint:js && npm run lint:types",
    "lint:fix": "npm run lint:js -- --fix",
    "lint:js": "eslint . --max-warnings 0",
    "lint:types": "tsc --noEmit",
    "test": "jest --color --coverage --verbose",
    "test:watch": "jest --color --watch",
    "test:unit": "jest --color --verbose --testPathIgnorePatterns=integration",
    "test:unit:watch": "jest --color --watch --testPathIgnorePatterns=integration",
    "test:integration": "jest --color --verbose --testPathPattern=integration",
    "test:integration:watch": "jest --color --watch --testPathPattern=integration",
    "server:watch": "NODE_ENV=development tsx watch --clear-screen=false --enable-source-maps --exclude \"**/*.test.*\"",
    "server:watch:dev": "npm run server:watch -- ./src/index.js",
    "server:watch:debug": "npm run server:watch --  --inspect=0.0.0.0:9229 ./src/index.js",
    "prestart": "npm run build",
    "start": "NODE_ENV=${NODE_ENV:-production} node --enable-source-maps ./.server",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "generate:jwt_secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "generate:token": "node scripts/generate-token.js",
    "generate:token:save": "node scripts/generate-token.js --save",
    "generate:broker-token": "node scripts/generate-broker-token.js",
    "generate:broker-token:save": "node scripts/generate-broker-token.js --save"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1009.0",
    "@aws-sdk/client-sns": "3.1009.0",
    "@aws-sdk/credential-providers": "3.1009.0",
    "@defra/forms-model": "3.0.637",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/hapi": "21.4.7",
    "@hapi/hoek": "11.0.7",
    "@hapi/jwt": "3.2.3",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "dotenv": "17.3.1",
    "hapi-pino": "13.0.0",
    "http-status-codes": "2.3.0",
    "joi": "17.13.3",
    "mongodb": "7.1.0",
    "pino": "9.14.0",
    "pino-pretty": "13.1.3",
    "proxy-agent": "6.5.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/plugin-syntax-import-attributes": "7.28.6",
    "@babel/preset-env": "7.29.0",
    "@eslint/core": "0.17.0",
    "@types/convict": "6.1.6",
    "@types/eslint": "9.6.1",
    "@types/jest": "29.5.14",
    "@types/node": "25.5.0",
    "@types/slug": "5.0.9",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "babel-jest": "30.3.0",
    "babel-plugin-module-resolver": "5.0.2",
    "babel-plugin-transform-import-meta": "2.3.3",
    "editorconfig-checker": "6.1.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "28.14.0",
    "eslint-plugin-jsdoc": "51.4.1",
    "eslint-plugin-n": "16.6.2",
    "eslint-plugin-promise": "6.6.0",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.4.0",
    "neostandard": "0.13.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.13.1",
    "npm": "11.8.0"
  }
}
